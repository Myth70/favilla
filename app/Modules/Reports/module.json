{
    "name": "Reports",
    "icon": "fa-solid fa-chart-bar",
    "version": "2.0.0",
    "changelog": {
        "1.0.0": "Versione iniziale",
        "1.1.0": "Document Templates: generazione PDF da singolo record",
        "2.0.0": "Riscrittura completa: modulo core, designer WYSIWYG riscritto, motore export unificato"
    },
    "description": "Sistema completo di esportazione dati e report con designer WYSIWYG, export CSV/Excel/PDF e document templates",
    "author": "Favilla",
    "database": "shared",
    "tables": [
        "report_style_presets",
        "report_templates",
        "report_history",
        "document_bindings"
    ],
    "dependencies": [],
    "search_provider": "App\\Modules\\Reports\\Providers\\ReportsSearchProvider",
    "services": [
        "FileUploadService"
    ],
    "assets": {
        "css": [
            "reports.css",
            "reports-grapesjs.css"
        ],
        "js": [
            "reports.js",
            "reports-grapesjs.js"
        ]
    },
    "uploads_directory": "reports",
    "admin_panel": {
        "section": "Sicurezza, privacy e controllo",
        "groups": [
            {
                "title": "Reportistica e documenti",
                "description": "Template, stili, storico export e binding documentali del modulo Reports.",
                "icon": "fa-solid fa-file-export",
                "flows": [
                    "Preview template",
                    "Quick export",
                    "Download storico"
                ],
                "links": [
                    {
                        "label": "Dashboard report",
                        "route": "reports.index",
                        "permission": "reports.view",
                        "description": "Punto di ingresso alla reportistica applicativa.",
                        "icon": "fa-solid fa-chart-column",
                        "keywords": "reports dashboard export"
                    },
                    {
                        "label": "Template report",
                        "route": "reports.templates.index",
                        "permission": "reports.view",
                        "description": "Catalogo template custom e bundled.",
                        "icon": "fa-solid fa-file-lines",
                        "keywords": "template report"
                    },
                    {
                        "label": "Nuovo template report",
                        "route": "reports.templates.new",
                        "permission": "reports.create",
                        "description": "Crea un nuovo modello di report dal wizard.",
                        "icon": "fa-solid fa-file-circle-plus",
                        "keywords": "crea template report wizard"
                    },
                    {
                        "label": "Storico export",
                        "route": "reports.history.index",
                        "permission": "reports.view",
                        "description": "Storico generazioni e download disponibili.",
                        "icon": "fa-solid fa-timeline",
                        "keywords": "history export report"
                    }
                ]
            }
        ]
    }
}

{
    "name": "favilla/favilla",
    "description": "Favilla — self-hosted workspace on a custom PHP 8.2 micro-framework",
    "type": "project",
    "keywords": ["workspace", "self-hosted", "intranet", "php", "mvc", "agpl"],
    "homepage": "https://github.com/Myth70/favilla",
    "license": "AGPL-3.0-or-later",
    "authors": [
        {
            "name": "Pietro Barone",
            "email": "pietrobarone70@proton.me",
            "role": "Maintainer"
        }
    ],
    "support": {
        "issues": "https://github.com/Myth70/favilla/issues",
        "security": "https://github.com/Myth70/favilla/security/advisories"
    },
    "require": {
        "php": "^8.2",
        "cerdic/css-tidy": "^2.2",
        "dompdf/dompdf": "^3.1",
        "ezyang/htmlpurifier": "^4.18",
        "monolog/monolog": "^3.0",
        "phpmailer/phpmailer": "^7.0",
        "phpoffice/phpspreadsheet": "^5.6.1",
        "vlucas/phpdotenv": "^5.6"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.0",
        "phpstan/phpstan": "^2.0",
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        },
        "files": [
            "app/Helpers/functions.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true,
        "platform": {
            "php": "8.2.0"
        }
    },
    "scripts": {
        "test": "phpunit",
        "test:core": "phpunit --testsuite Core",
        "test:modules": "phpunit --testsuite Modules",
        "stan": "phpstan analyse -c phpstan.neon",
        "cs": "php-cs-fixer fix --dry-run --diff",
        "cs:fix": "php-cs-fixer fix",
        "security": "@composer audit"
    }
}

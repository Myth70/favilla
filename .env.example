# ==============================================================
# FAVILLA — Configurazione ambiente
# Copia questo file in .env e adatta i valori.
# Il file .env NON deve mai essere committato su git.
# ==============================================================

# Percorso del binario PHP usato dallo scheduler (cron)
# XAMPP Windows: C:\xampp\php\php.exe — Linux/Docker: php
SCHEDULER_PHP_BINARY=php

# Timeout massimo (secondi) per l'esecuzione di un singolo job dello scheduler
SCHEDULER_EXECUTION_TIMEOUT=120

# --------------------------------------------------------------
# Applicazione
# --------------------------------------------------------------
APP_NAME="Favilla"

# development | production
APP_ENV=production

# true solo in sviluppo — mostra errori dettagliati nel browser
APP_DEBUG=false

# URL base dell'app SENZA trailing slash e SENZA /public
# XAMPP dev:   http://localhost
# Produzione:  https://workspace.example.com
# Docker:      http://localhost:8080
APP_URL=http://localhost

# Chiave crittografica per i token CSRF (32 byte esadecimali)
# Genera con: php -r "echo bin2hex(random_bytes(32));"
APP_KEY=

# Base path per URL generation (aggiunto al dominio per generare URL)
# Produzione/Docker: (vuoto — DocumentRoot punta a public/)
# XAMPP dev in sottocartella: /favilla
APP_BASE_PATH=

# Timezone PHP per timestamp coerenti tra dev/prod e nei log
APP_TIMEZONE=Europe/Rome

# Edizione: developer | personal | team (vuoto = usa la scelta del setup)
APP_EDITION=

# --------------------------------------------------------------
# Database — MariaDB / MySQL
# --------------------------------------------------------------
# Docker: usa il nome del servizio (es. "db")
# XAMPP dev: "localhost"
DB_HOST=localhost
DB_PORT=3306
DB_NAME=favilla
DB_USER=favilla
DB_PASS=
DB_CHARSET=utf8mb4

# Password root del container MariaDB — richiesta SOLO con Docker.
# Deve essere DIVERSA da DB_PASS (non usata da XAMPP).
# Genera con: php -r "echo bin2hex(random_bytes(16));"
DB_ROOT_PASS=

# --------------------------------------------------------------
# Sessioni
# --------------------------------------------------------------
# Durata in minuti (480 = 8 ore)
SESSION_LIFETIME=480
# Percorso relativo alla root del progetto
SESSION_PATH=/storage/sessions
# Storage delle sessioni: file (default) | database
SESSION_DRIVER=file

# --------------------------------------------------------------
# Rate limiting login
# --------------------------------------------------------------
# Numero massimo di tentativi prima del blocco
RATE_LIMIT_LOGIN=5
# Finestra temporale in minuti
RATE_LIMIT_WINDOW=15

# --------------------------------------------------------------
# Sicurezza / Transport
# --------------------------------------------------------------
# Abilita l'header HSTS. Effettivo SOLO su HTTPS reale (mai da header proxy
# falsificabili). Attiva solo quando il dominio è servito stabilmente in TLS.
HSTS_ENABLED=false

# Proxy fidati per la risoluzione dell'IP client e dello schema (X-Forwarded-*).
# Lista separata da virgole di IP o CIDR del/dei reverse proxy davanti all'app.
# Vuoto = nessun proxy fidato (usa l'IP della connessione diretta).
# Esempio dietro un proxy locale: 127.0.0.1,::1
TRUSTED_PROXIES=

# --------------------------------------------------------------
# Log (Monolog)
# --------------------------------------------------------------
# debug | info | notice | warning | error | critical | alert | emergency
# Produzione: usare "error" o "warning"
LOG_LEVEL=error
# Percorso relativo alla root del progetto
LOG_PATH=/storage/logs

# --------------------------------------------------------------
# Manutenzione
# --------------------------------------------------------------
# true = mostra pagina di manutenzione a tutti gli utenti
MAINTENANCE_MODE=false

# --------------------------------------------------------------
# Report — generazione PDF
# --------------------------------------------------------------
# Consente a Dompdf di scaricare immagini/risorse remote (http/https) nei PDF.
# SCONSIGLIATO: con i template HTML autori-controllati abilita richieste lato
# server arbitrarie (SSRF). Lascia false; i loghi locali sono incorporati inline.
REPORTS_PDF_ALLOW_REMOTE=false

# --------------------------------------------------------------
# Backup — cifratura
# --------------------------------------------------------------
# Chiave AES-256-CBC per cifratura backup (32 byte esadecimali)
# Genera con: php -r "echo bin2hex(random_bytes(32));"
BACKUP_ENCRYPTION_KEY=

# Numero massimo di backup conservati (rotazione: i più vecchi vengono eliminati)
BACKUP_MAX_COUNT=10

# Tabelle da escludere dal dump (lista separata da virgole). Vuoto = nessuna esclusione.
BACKUP_EXCLUDE_TABLES=

# Consente il backup non cifrato anche di DB grandi (SCONSIGLIATO in produzione).
BACKUP_ALLOW_UNENCRYPTED_LARGE=false

# Se true, il backup fallisce quando il DB di un modulo risulta mancante,
# invece di proseguire saltandolo.
BACKUP_FAIL_ON_MISSING_MODULE_DB=false

# Include nel backup anche i file caricati (public/uploads + storage/uploads,
# quindi avatar, allegati, Files e storage Documenti). Con la cifratura attiva
# ricordare il cap in-memory: archivi molto grandi richiedono di disattivare
# la cifratura, escludere i file o usare BACKUP_ALLOW_UNENCRYPTED_LARGE.
BACKUP_INCLUDE_FILES=true

# --------------------------------------------------------------
# Meteo (widget dashboard Home)
# --------------------------------------------------------------
# Coordinate e label della località per il widget meteo. Possono essere
# sovrascritte dalle impostazioni applicazione (tabella app_settings).
WEATHER_LAT=
WEATHER_LON=
WEATHER_LABEL=

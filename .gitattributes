# Normalize all text files to LF in the repository
* text=auto eol=lf

# Shell scripts must stay LF (executed inside Linux containers)
*.sh text eol=lf
entrypoint.sh text eol=lf

# Windows scripts keep CRLF
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.otf binary
*.pdf binary
*.zip binary
*.gz binary

# ── Keep dev-only files out of distribution archives (git archive / dist) ──
/.github               export-ignore
/tests                 export-ignore
/docs/contracts        export-ignore
/docs/screenshots      export-ignore
/.editorconfig         export-ignore
/.php-cs-fixer.dist.php export-ignore
/phpstan.neon          export-ignore
/phpstan-baseline.neon export-ignore
/phpstan-bootstrap.php export-ignore
/phpunit.xml           export-ignore
/CLAUDE.md             export-ignore
/.gitattributes        export-ignore
/.gitignore            export-ignore
/context               export-ignore
/project_context.json  export-ignore
/app/Modules/_Template export-ignore
/tools                 export-ignore
